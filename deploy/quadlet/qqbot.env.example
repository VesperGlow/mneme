# 此文件安装后应改名为 qqbot.env，并 chmod 600。
QQ_APP_ID=replace-with-qq-app-id
QQ_APP_SECRET=replace-with-qq-app-secret
# WebSocket 主动连接 QQ，不需要公网域名或反向代理。
QQ_EVENT_MODE=websocket

# 必须与 app.env 中的 APP_API_KEY 完全一致。
APP_API_KEY=change-me-to-a-long-random-string
QQ_AI_URL=http://qq-agent-app:8000/v1/chat
QQ_LISTEN_ADDR=:9000
QQ_WEBHOOK_PATH=/qqbot
QQ_AI_TIMEOUT_SECONDS=180
QQ_OPENAPI_TIMEOUT_SECONDS=15
# 仅处理私聊(C2C)，不支持群/频道。
QQ_BOT_DEBUG=false
QQ_REPLY_MAX_RUNES=1800
QQ_REPLY_MAX_PARTS=4
QQ_WORKERS=8
QQ_QUEUE_SIZE=128
QQ_DEDUP_TTL_SECONDS=600
QQ_MAX_WEBHOOK_BYTES=1048576

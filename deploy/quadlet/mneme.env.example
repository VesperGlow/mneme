# 此文件安装后应改名为 mneme.env，并 chmod 600。
# 全部配置项就这些；其余行为固定在代码里（src/config.rs 顶部的常量）。

# DeepSeek 是唯一的模型供应商，且全局只用一个模型 deepseek-v4-pro：
# 对话开思考（等级 max），记忆侧用同一模型但关思考。均写死在代码里。
DEEPSEEK_API_KEY=sk-你的KEY

APP_API_KEY=change-me-to-a-long-random-string
LOG_LEVEL=INFO
# 全局人设：只写性格/口吻，对 QQ/网页/API 全部生效。系统指令层（格式/工具/安全）始终生效。留空用默认人设。
PERSONA_PROMPT=
# 系统指令层：留空即用代码里的完整默认内容；想整体替换时才填，多行用字面量 \n 分隔。
SYSTEM_INSTRUCTIONS=

# 存储内嵌在容器里，无需外部服务。
DB_PATH=/data/memory.db

# 远程 MCP 工具（可选）。URL 里 ${NAME} 会展开成下面的环境变量，只需填 key。
# 网页抓取由内置 fetch_url 承担（始终启用），这里只留联网搜索。留空 [] 则不启用。
TAVILY_KEY=tvly-你的KEY
MCP_SERVERS_JSON=[{"name":"tavily","url":"https://mcp.tavily.com/mcp/?tavilyApiKey=${TAVILY_KEY}","tools":["tavily_search"]}]

# ---------- QQ 机器人（官方开放平台协议，与 AI 同一进程，仅私聊 C2C） ----------
QQ_APP_ID=replace-with-qq-app-id
QQ_APP_SECRET=replace-with-qq-app-secret
# WebSocket 主动连接 QQ，不需要公网域名或反向代理。
# webhook 模式的回调路径固定 /qqbot，容器内端口固定 9000。
QQ_EVENT_MODE=websocket

# Mneme 的全部配置项就这些。其余行为（模型名、思考等级、记忆策略、超时、限流……）
# 都固定在代码里（src/config.rs 顶部的常量），要调就改代码重新构建。

# ---------- DeepSeek（唯一的模型供应商） ----------
# https://platform.deepseek.com 申请。对话用 deepseek-v4-pro + 思考等级 max，
# 记忆（精选/巩固/摘要）用 deepseek-v4-flash 且关闭思考，都写死在代码里。
DEEPSEEK_API_KEY=sk-你的KEY

# ---------- 对外 API ----------
# 留空则不鉴权；部署到公网时务必设置为长随机字符串。
APP_API_KEY=change-me-to-a-long-random-string
LOG_LEVEL=INFO
# 全局人设：只写性格/口吻即可，对 QQ、网页 UI、直连 API 全部生效。留空用内置默认人设。
# 输出格式（禁用 Markdown）、记忆/工具与安全属于独立的系统指令层，始终生效、不必在此重复。
# 例：PERSONA_PROMPT=你是一只傲娇但乐于助人的猫娘助手，说话简洁、偶尔加“喵”。
PERSONA_PROMPT=
# 系统指令层：输出格式（禁用 Markdown）+ 记忆/工具 + 安全，优先级高于人设，始终生效。
# 留空即用代码里的完整默认内容（src/agent.rs 的 DEFAULT_SYSTEM_INSTRUCTIONS），一般不必填。
# 想整体替换时才写这里；多行用字面量 \n 分隔（运行时会还原为换行），并自行保留格式与安全约束。
SYSTEM_INSTRUCTIONS=

# ---------- 存储 ----------
# SQLite 数据库文件：对话、记忆、情绪全在这一个文件里（容器内路径，对应 app_data 卷）。
DB_PATH=/data/memory.db

# ---------- MCP 工具（可选，给对话模型接入外部工具） ----------
# 工具会以 mcp__<name>__<tool> 的形式暴露给对话模型。
# URL 与 headers 里可用 ${NAME} 引用下面的环境变量，因此只需在 env 填 key。
# 网页抓取已由内置 fetch_url 承担（始终启用），这里默认只留 Tavily 联网搜索。
TAVILY_KEY=tvly-你的KEY
# 留空 [] 表示不启用任何外部 MCP 工具。
MCP_SERVERS_JSON=[{"name":"tavily","url":"https://mcp.tavily.com/mcp/?tavilyApiKey=${TAVILY_KEY}","tools":["tavily_search"]}]

# ---------- QQ 机器人（官方开放平台协议，仅私聊 C2C） ----------
QQ_APP_ID=
QQ_APP_SECRET=
# websocket 由容器主动连接 QQ，无需公网入口；webhook 需要公网 HTTPS 回调，
# 回调路径固定为 /qqbot，容器内端口固定 9000。
QQ_EVENT_MODE=webhook

# ---------- 仅供 compose 使用（不会被程序读取） ----------
APP_IMAGE=ghcr.io/vesperglow/mneme:latest
APP_BIND_IP=127.0.0.1
APP_PORT=8000
QQ_BOT_BIND_IP=127.0.0.1
QQ_BOT_PORT=9000
